{
  "name": "twitterapi",
  "version": "0.2.0",
  "description": "A TypeScript CLI for TwitterAPI.io with stable JSON output and agent-friendly ergonomics.",
  "keywords": [
    "twitter",
    "x",
    "twitterapi",
    "twitterapi.io",
    "cli",
    "typescript"
  ],
  "homepage": "https://github.com/lcandy2/twitterapi-cli#readme",
  "bugs": {
    "url": "https://github.com/lcandy2/twitterapi-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lcandy2/twitterapi-cli.git"
  },
  "type": "module",
  "bin": {
    "twitterapi-cli": "dist/bin.js",
    "twitterapi": "dist/bin.js",
    "twapi": "dist/bin.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx src/bin.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.12.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
